---
import '../styles/global.css';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'The Happy Class for Couples',
  description: 'A DIY alternative to couples counseling. A physical kit couples do together. Making something good even better.',
  brand: {
    '@type': 'Brand',
    name: 'The Happy Class',
  },
  creator: {
    '@type': 'Person',
    name: 'Sandra Weise',
    url: 'https://sandraweise.com',
  },
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Happy Class: Making Something Good Even Better</title>
  <meta name="description" content="The Happy Class for Couples. A DIY alternative to couples counseling. A physical kit couples do together. Not therapy. Not fixing. Just making something good even better." />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="The Happy Class: Making Something Good Even Better" />
  <meta property="og:description" content="A DIY alternative to couples counseling. A physical kit couples do together. Coming October 2026." />
  <meta property="og:url" content="https://thehappyclass.com" />
  <meta property="og:site_name" content="The Happy Class" />
  <meta name="twitter:card" content="summary_large_image" />

  <meta name="theme-color" content="#0A0A0A" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Allura&family=Cinzel:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>

  <!-- ═══ HEADER ═══ -->
  <header class="site-header">
    <div class="container site-header__inner">
      <a href="#top" class="wordmark">The Happy Class</a>
      <a href="#waitlist-hero" class="btn btn--ghost">Join the Waitlist</a>
