    <span class="confetti confetti--sky"    style="width:14px;height:14px;bottom:10%;left:6%;"></span>
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--space-lg);">
        <p class="overline">How it works</p>
        <h2>Simple. Intentional. <span class="script script--sky">Yours.</span></h2>
      </div>

