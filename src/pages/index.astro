</html>

<!-- Cloudflare Turnstile -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const btn = document.getElementById('waitlist-btn')!;
  const status = document.getElementById('waitlist-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const turnstileInput = form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement;
    const token = turnstileInput?.value;

    if (!token) {
      status.className = 'waitlist-status error';
      status.textContent = 'Please complete the verification.';
      return;
    }

    (btn as HTMLButtonElement).disabled = true;
    btn.querySelector('.submit-text')!.style.display = 'none';
    btn.querySelector('.submit-loading')!.style.display = 'inline';
    status.className = 'waitlist-status';
    status.textContent = '';

    const fd = new FormData(form);
    try {
      const res = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: fd.get('name') || '',
          email: fd.get('email'),
          token,
        }),
      });
      if (res.ok) {
        status.className = 'waitlist-status success';
        status.textContent = "You're on the list. We'll be in touch.";
        form.reset();
        if (window.turnstile) window.turnstile.reset();
      } else {
        const err = await res.json().catch(() => ({ error: 'Something went wrong.' }));
        status.className = 'waitlist-status error';
        status.textContent = err.error || 'Something went wrong. Try again.';
      }
    } catch {
      status.className = 'waitlist-status error';
      status.textContent = 'Network error. Please try again.';
    } finally {
      (btn as HTMLButtonElement).disabled = false;
      btn.querySelector('.submit-text')!.style.display = 'inline';
      btn.querySelector('.submit-loading')!.style.display = 'none';
    }
  });
</script>

<style>
  /* ═══ HERO ═══ */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(140deg, var(--linen) 0%, var(--blush-soft) 30%, var(--sky-soft) 65%, var(--butter-soft) 100%);
