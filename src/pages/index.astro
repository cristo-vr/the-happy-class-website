    </div>
  </footer>

</body>
</html>

<!-- Cloudflare Turnstile -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  document.querySelectorAll<HTMLFormElement>('form[data-waitlist]').forEach((form) => {
    const btn = form.querySelector('.waitlist-submit') as HTMLButtonElement;
    const status = form.querySelector('.waitlist-status')!;
    const submitText = btn.querySelector('.submit-text') as HTMLElement;
    const submitLoading = btn.querySelector('.submit-loading') as HTMLElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const turnstileInput = form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement;
      const token = turnstileInput?.value;

      if (!token) {
        status.className = 'waitlist-status error';
        status.textContent = 'Please complete the verification.';
        return;
      }

      btn.disabled = true;
      submitText.style.display = 'none';
      submitLoading.style.display = 'inline';
      status.className = 'waitlist-status';
      status.textContent = '';

      const fd = new FormData(form);
      try {
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: fd.get('name') || '',
            email: fd.get('email'),
            token,
          }),
        });
        if (res.ok) {
          status.className = 'waitlist-status success';
          status.textContent = "You're on the list. We'll be in touch.";
          form.reset();
          if (window.turnstile) window.turnstile.reset();
        } else {
          const err = await res.json().catch(() => ({ error: 'Something went wrong.' }));
          status.className = 'waitlist-status error';
          status.textContent = err.error || 'Something went wrong. Try again.';
        }
      } catch {
        status.className = 'waitlist-status error';
        status.textContent = 'Network error. Please try again.';
      } finally {
        btn.disabled = false;
        submitText.style.display = 'inline';
        submitLoading.style.display = 'none';
      }
    });
  });
</script>

<style>
  /* ═══ HEADER ═══ */
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    background: rgba(10, 10, 10, 0.78);
