            <span class="confetti confetti--blush" style="width:16px;height:16px;top:-10px;left:-12px;"></span>
            <span class="confetti confetti--butter" style="width:12px;height:12px;bottom:8%;right:-10px;"></span>
          </div>
        </div>
        <div class="split__content">
          <p class="overline">Validated</p>
          <h2>We tested it. <span class="script script--rose">Men loved it.</span></h2>
