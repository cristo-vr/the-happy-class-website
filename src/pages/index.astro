  .hero__title {
    display: contents;
    margin: 0;
  }
  .hero__title-top,
  .hero__title-bottom {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.035em;
