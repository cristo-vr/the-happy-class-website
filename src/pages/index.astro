---
import '../styles/global.css';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'The Happy Class for Couples',
  description: 'A DIY alternative to couples counseling. A physical kit couples do together. Making something good even better.',
  brand: {
    '@type': 'Brand',
    name: 'The Happy Class',
  },
  creator: {
    '@type': 'Person',
    name: 'Sandra Weise',
    url: 'https://sandraweise.com',
  },
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Happy Class — Making Something Good Even Better</title>
  <meta name="description" content="The Happy Class for Couples — a DIY alternative to couples counseling. A physical kit couples do together. Not therapy. Not fixing. Just making something good even better." />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="The Happy Class — Making Something Good Even Better" />
  <meta property="og:description" content="A DIY alternative to couples counseling. A physical kit couples do together. Coming October 2026." />
  <meta property="og:url" content="https://thehappyclass.com" />
  <meta property="og:site_name" content="The Happy Class" />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <div class="hero__circle hero__circle--1"></div>
      <div class="hero__circle hero__circle--2"></div>
      <div class="hero__circle hero__circle--3"></div>
      <div class="hero__circle hero__circle--4"></div>
    </div>
    <div class="container hero__content">
      <p class="hero__label">The Happy Class for Couples</p>
      <h1>Making something good<br /><span class="hero__accent">even better.</span></h1>
      <p class="hero__sub">A DIY alternative to couples counseling. Not because something's broken — because you want to keep it great.</p>
      <a href="#waitlist" class="btn btn--rose btn--large">Join the Waitlist</a>
      <p class="hero__launch">Launching October 2026</p>
    </div>
  </section>

  <!-- ═══ THE PROBLEM ═══ -->
  <section class="section" id="what">
    <div class="container text-center">
      <p class="overline">Here's the thing</p>
      <h2>Most couples don't need therapy.<br />They need <em>better structure.</em></h2>
      <p class="mx-auto lead">You're not in crisis. You're not falling apart. You love each other. But somewhere along the way, the conversations got shorter, the check-ins stopped, and "we're fine" became the answer to everything. You're good. But you know you could be better.</p>
    </div>
  </section>

  <!-- ═══ WHAT IT IS ═══ -->
  <section class="section bg-linen">
    <div class="container">
      <div class="split">
        <div class="split__content">
          <p class="overline">What is The Happy Class?</p>
          <h2>A kit you do together.</h2>
          <p>The Happy Class is a physical product — a beautifully designed box that gives you and your partner the structure to have the conversations you've been putting off. Not heavy therapy conversations. Real ones. Honest ones. The kind that remind you why you chose each other.</p>
          <p>It's guided. It's structured. It's actually fun. And when you're done, you know each other better than you did when you started.</p>
        </div>
        <div class="split__visual">
          <div class="product-preview">
            <div class="paper paper--pink">
              <span class="paper__label">About your partner</span>
            </div>
            <div class="paper paper--blue">
              <span class="paper__label">About you</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WHO IT'S FOR ═══ -->
  <section class="section">
    <div class="container text-center">
      <p class="overline">Who it's for</p>
      <h2>Couples who are good —<br />and want to be <em>great.</em></h2>

      <div class="cards">
        <div class="card">
          <div class="card__icon card__icon--rose">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3>You're solid</h3>
          <p>You're not in trouble. You're not looking for a lifeline. You just know that good relationships don't maintain themselves — they need attention.</p>
        </div>
        <div class="card">
          <div class="card__icon card__icon--sky">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3>You want to talk</h3>
          <p>Not about logistics. Not about the kids' schedule. You want the real stuff — the stuff that gets buried under busy. You just need a way in.</p>
        </div>
        <div class="card">
          <div class="card__icon card__icon--sage">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </div>
          <h3>Therapy feels like too much</h3>
          <p>You don't need a therapist. You don't need a crisis. You just need a framework that makes it easy to check in with each other — on your own terms, in your own home.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="section bg-espresso">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--space-lg);">
        <p class="overline overline--light">How it works</p>
        <h2 style="color: var(--linen);">Simple. Intentional. Yours.</h2>
      </div>

      <div class="steps">
        <div class="step">
          <span class="step__number">01</span>
          <div class="step__paper step__paper--pink"></div>
          <h3>Pick up the pink paper.</h3>
          <p>Write about your partner. What you see. What you appreciate. What you wish they knew.</p>
        </div>
        <div class="step">
          <span class="step__number">02</span>
          <div class="step__paper step__paper--blue"></div>
          <h3>Pick up the blue paper.</h3>
          <p>Write about yourself. What you need. What you're carrying. What you haven't said out loud yet.</p>
        </div>
        <div class="step">
          <span class="step__number">03</span>
          <div class="step__paper step__paper--both"></div>
          <h3>Come together.</h3>
          <p>Share what you wrote. Follow the guided prompts. Have the conversation. It's not about being perfect — it's about being present.</p>
        </div>
      </div>

      <div class="text-center" style="margin-top: var(--space-lg);">
        <p style="color: rgba(250,246,240,0.5); font-size: 0.9375rem;">Think of it as an annual relationship check-in. Like a physical for your partnership.</p>
      </div>
    </div>
  </section>

  <!-- ═══ THE VISION ═══ -->
  <section class="section">
    <div class="container container--narrow text-center">
      <p class="overline">The story behind it</p>
      <h2>Twenty years of sitting across<br />from people in the moments<br />that matter most.</h2>
      <p class="mx-auto" style="margin-top: 1.5rem;">I'm Sandra Weise. I've been a life coach for over two decades. I've sat with thousands of people — couples, families, individuals — at the exact moment they realize something needs to change.</p>
      <p class="mx-auto">Here's what I've learned: most couples who walk into a coaching session aren't broken. They're just out of practice. They stopped checking in. They stopped asking each other the real questions. And over time, "fine" replaced "great."</p>
      <p class="mx-auto">The Happy Class is everything I've learned about what makes relationships work — distilled into something you can do at home, together, without a coach in the room. Because you don't need me. You need each other. And a better structure.</p>
      <p class="mx-auto" style="margin-top: 1.5rem;"><a href="https://sandraweise.com" class="text-link">More about Sandra &rarr;</a></p>
    </div>
  </section>

  <!-- ═══ SOCIAL PROOF ═══ -->
  <section class="section bg-linen">
    <div class="container text-center">
      <p class="overline">Validated</p>
      <h2>We tested it with 100 men.</h2>
      <p class="mx-auto lead">Focus groups are usually lucky to get a 5% comment rate. We got 50%. Half the men in the room left comments. They loved the name. They loved the concept. They didn't feel like they were being asked to "do therapy." They felt like they were being invited to do something good for their relationship.</p>

      <div class="proof-stats">
        <div class="proof-stat">
          <span class="proof-stat__number">100</span>
          <span class="proof-stat__label">Men in the focus group</span>
        </div>
        <div class="proof-stat">
          <span class="proof-stat__number">50%</span>
          <span class="proof-stat__label">Left written feedback</span>
        </div>
      </div>

      <p class="mx-auto" style="margin-top: 2rem; font-style: italic; color: var(--text-muted);">"Getting men to not resist this is 51% of the battle. The name does that."</p>
    </div>
  </section>

  <!-- ═══ THE ROADMAP ═══ -->
  <section class="section">
    <div class="container text-center">
      <p class="overline">What's coming</p>
      <h2>Couples first.<br />Then <em>everyone.</em></h2>
      <p class="mx-auto" style="margin-bottom: var(--space-lg);">The Happy Class for Couples is just the beginning. The same framework works for every relationship that matters.</p>

      <div class="roadmap">
        <div class="roadmap__item roadmap__item--active">
          <span class="roadmap__dot"></span>
          <h4>Couples</h4>
          <p>October 2026</p>
        </div>
        <div class="roadmap__item">
          <span class="roadmap__dot"></span>
          <h4>Friends</h4>
          <p>2027</p>
        </div>
        <div class="roadmap__item">
          <span class="roadmap__dot"></span>
          <h4>Siblings</h4>
          <p>2027</p>
        </div>
        <div class="roadmap__item">
          <span class="roadmap__dot"></span>
          <h4>Mothers & Daughters</h4>
          <p>2027</p>
        </div>
        <div class="roadmap__item">
          <span class="roadmap__dot"></span>
          <h4>Fathers & Sons</h4>
          <p>2027</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WAITLIST ═══ -->
  <section class="section bg-espresso" id="waitlist">
    <div class="container container--narrow text-center">
      <h2 style="color: var(--linen);">Be the first to know.</h2>
      <p style="color: rgba(250,246,240,0.6); margin: 1rem auto 2.5rem; max-width: 480px;">The Happy Class for Couples launches October 2026. Drop your email and we'll let you know the moment it's ready.</p>

      <form id="waitlist-form" class="waitlist-form">
        <div class="waitlist-form__row">
          <input type="text" name="name" placeholder="First name (optional)" class="waitlist-input" />
          <input type="email" name="email" placeholder="Your email" class="waitlist-input" required />
        </div>
        <div class="cf-turnstile" data-sitekey="YOUR_TURNSTILE_SITE_KEY" data-theme="dark"></div>
        <button type="submit" class="btn btn--rose btn--large waitlist-submit" id="waitlist-btn">
          <span class="submit-text">Join the Waitlist</span>
          <span class="submit-loading" style="display:none;">Adding you...</span>
        </button>
        <div id="waitlist-status" class="waitlist-status" role="alert"></div>
      </form>

      <p style="color: rgba(250,246,240,0.3); font-size: 0.8125rem; margin-top: 1.5rem;">No spam. Just one email when it's time. That's it.</p>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="footer">
    <div class="container text-center">
      <p class="footer__brand">The Happy Class</p>
      <p class="footer__tagline">Making something good even better.</p>
      <div class="footer__links">
        <a href="https://sandraweise.com" target="_blank" rel="noopener noreferrer">sandraweise.com</a>
        <span class="footer__sep">&middot;</span>
        <a href="https://www.instagram.com/sandraweise/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <span class="footer__sep">&middot;</span>
        <a href="https://sandraweise.com/podcast" target="_blank" rel="noopener noreferrer">A Better Question</a>
      </div>
      <p class="footer__copy">&copy; {new Date().getFullYear()} The Happy Class. All rights reserved.</p>
    </div>
  </footer>

</body>
</html>

<!-- Cloudflare Turnstile -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const btn = document.getElementById('waitlist-btn')!;
  const status = document.getElementById('waitlist-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const turnstileInput = form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement;
    const token = turnstileInput?.value;

    if (!token) {
      status.className = 'waitlist-status error';
      status.textContent = 'Please complete the verification.';
      return;
    }

    (btn as HTMLButtonElement).disabled = true;
    btn.querySelector('.submit-text')!.style.display = 'none';
    btn.querySelector('.submit-loading')!.style.display = 'inline';
    status.className = 'waitlist-status';
    status.textContent = '';

    const fd = new FormData(form);
    try {
      const res = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: fd.get('name') || '',
          email: fd.get('email'),
          token,
        }),
      });
      if (res.ok) {
        status.className = 'waitlist-status success';
        status.textContent = "You're on the list. We'll be in touch.";
        form.reset();
        if (window.turnstile) window.turnstile.reset();
      } else {
        const err = await res.json().catch(() => ({ error: 'Something went wrong.' }));
        status.className = 'waitlist-status error';
        status.textContent = err.error || 'Something went wrong. Try again.';
      }
    } catch {
      status.className = 'waitlist-status error';
      status.textContent = 'Network error. Please try again.';
    } finally {
      (btn as HTMLButtonElement).disabled = false;
      btn.querySelector('.submit-text')!.style.display = 'inline';
      btn.querySelector('.submit-loading')!.style.display = 'none';
    }
  });
</script>

<style>
  /* ═══ HERO ═══ */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--espresso);
    overflow: hidden;
    text-align: center;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__circle {
    position: absolute;
    border-radius: 50%;
  }
  .hero__circle--1 { width: 500px; height: 500px; background: var(--rose); opacity: 0.06; top: -180px; right: -120px; }
  .hero__circle--2 { width: 350px; height: 350px; background: var(--sky); opacity: 0.05; bottom: -100px; left: -80px; }
  .hero__circle--3 { width: 200px; height: 200px; background: var(--citrine); opacity: 0.04; top: 30%; left: 10%; }
  .hero__circle--4 { width: 280px; height: 280px; background: var(--sage); opacity: 0.04; bottom: 10%; right: 15%; }

  .hero__content {
    position: relative;
    z-index: 2;
    padding: 2rem 0;
  }

  .hero__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    color: var(--linen);
    margin-bottom: 1.5rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__accent {
    color: var(--rose);
  }

  .hero__sub {
    font-size: 1.125rem;
    color: rgba(250, 246, 240, 0.6);
    max-width: 500px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero__launch {
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: rgba(250, 246, 240, 0.35);
    letter-spacing: 0.1em;
  }

  /* ═══ OVERLINE ═══ */
  .overline {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--rose-deep);
    margin-bottom: 0.75rem;
  }

  .overline--light {
    color: var(--rose);
  }

  /* ═══ LEAD TEXT ═══ */
  .lead {
    font-size: 1.125rem;
    color: var(--text-muted);
    margin-top: 1.25rem;
  }

  em {
    font-style: italic;
    color: var(--espresso);
  }

  /* ═══ BG VARIANTS ═══ */
  .bg-linen { background: var(--linen); }
  .bg-espresso { background: var(--espresso); }

  /* ═══ SPLIT LAYOUT ═══ */
  .split {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .split__content p {
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .split__content h2 {
    margin-bottom: 1.25rem;
  }

  @media (max-width: 768px) {
    .split { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  /* ═══ PRODUCT PREVIEW (pink/blue paper) ═══ */
  .product-preview {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  .paper {
    width: 160px;
    height: 220px;
    border-radius: 1rem;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 1.25rem;
    position: relative;
    box-shadow: 0 8px 32px rgba(44, 29, 18, 0.1);
    transition: transform 0.3s ease;
  }

  .paper:hover {
    transform: translateY(-4px) rotate(-1deg);
  }

  .paper--pink {
    background: linear-gradient(145deg, #F5E1E3, var(--rose));
    transform: rotate(-3deg);
  }

  .paper--blue {
    background: linear-gradient(145deg, #D4E5F0, var(--sky));
    transform: rotate(2deg);
  }

  .paper--pink:hover { transform: translateY(-4px) rotate(-4deg); }
  .paper--blue:hover { transform: translateY(-4px) rotate(1deg); }

  .paper__label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(44, 29, 18, 0.5);
  }

  /* ═══ CARDS ═══ */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: var(--space-lg);
  }

  .card {
    background: white;
    border-radius: 1.5rem;
    padding: 2.25rem;
    text-align: left;
    box-shadow: 0 2px 12px rgba(44, 29, 18, 0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(44, 29, 18, 0.1);
  }

  .card__icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .card__icon--rose { background: rgba(232, 180, 184, 0.2); color: var(--rose-deep); }
  .card__icon--sky { background: rgba(184, 212, 227, 0.3); color: var(--indigo); }
  .card__icon--sage { background: rgba(156, 175, 136, 0.15); color: var(--sage); }

  .card h3 {
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
  }

  .card p {
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .cards { grid-template-columns: 1fr; }
  }

  /* ═══ STEPS ═══ */
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .step {
    text-align: center;
  }

  .step__number {
    display: block;
    font-family: 'Lora', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: rgba(250, 246, 240, 0.12);
    margin-bottom: 1rem;
  }

  .step__paper {
    width: 60px;
    height: 80px;
    border-radius: 0.5rem;
    margin: 0 auto 1.25rem;
  }

  .step__paper--pink { background: linear-gradient(145deg, #F5E1E3, var(--rose)); transform: rotate(-2deg); }
  .step__paper--blue { background: linear-gradient(145deg, #D4E5F0, var(--sky)); transform: rotate(2deg); }
  .step__paper--both {
    background: linear-gradient(135deg, var(--rose) 50%, var(--sky) 50%);
    transform: rotate(0deg);
  }

  .step h3 {
    color: var(--linen);
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }

  .step p {
    color: rgba(250, 246, 240, 0.55);
    font-size: 0.9375rem;
    line-height: 1.7;
    max-width: 280px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .steps { grid-template-columns: 1fr; gap: 3rem; }
  }

  /* ═══ PROOF STATS ═══ */
  .proof-stats {
    display: flex;
    justify-content: center;
    gap: 4rem;
    margin-top: 2.5rem;
  }

  .proof-stat {
    display: flex;
    flex-direction: column;
  }

  .proof-stat__number {
    font-family: 'Lora', serif;
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--espresso);
    line-height: 1;
  }

  .proof-stat__label {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 0.375rem;
  }

  /* ═══ ROADMAP ═══ */
  .roadmap {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    position: relative;
  }

  .roadmap__item {
    text-align: center;
    min-width: 120px;
  }

  .roadmap__dot {
    display: block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--sand);
    margin: 0 auto 1rem;
    position: relative;
