        </div>
        <div class="roadmap__item">
          <span class="roadmap__dot"></span>
          <h4>Friends</h4>
          <p>2027</p>
        </div>
        <div class="roadmap__item">
          <span class="roadmap__dot"></span>
          <h4>Siblings</h4>
          <p>2027</p>
        </div>
        <div class="roadmap__item">
          <span class="roadmap__dot"></span>
          <h4>Mothers & Daughters</h4>
          <p>2027</p>
        </div>
        <div class="roadmap__item">
          <span class="roadmap__dot"></span>
          <h4>Fathers & Sons</h4>
          <p>2027</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WAITLIST ═══ -->
