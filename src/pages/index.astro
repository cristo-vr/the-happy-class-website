    <span class="confetti confetti--butter" style="width:14px;height:14px;top:10%;left:6%;"></span>
    <span class="confetti confetti--sky"    style="width:10px;height:10px;bottom:14%;right:10%;"></span>
    <div class="container">
      <div class="split">
