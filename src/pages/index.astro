    <div class="hero__bg" aria-hidden="true">
      <div class="hero__grid-pattern"></div>
      <div class="hero__glow hero__glow--gold"></div>
      <div class="hero__glow hero__glow--deep"></div>
    </div>

    <div class="container hero__stack">
      <div class="hero__chip">
