---
import '../styles/global.css';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'The Happy Class for Couples',
  description: 'A DIY alternative to couples counseling. A physical kit couples do together. Making something good even better.',
  brand: {
    '@type': 'Brand',
    name: 'The Happy Class',
  },
  creator: {
    '@type': 'Person',
    name: 'Sandra Weise',
    url: 'https://sandraweise.com',
  },
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Happy Class - Making Something Good Even Better</title>
  <meta name="description" content="The Happy Class for Couples - a DIY alternative to couples counseling. A physical kit couples do together. Not therapy. Not fixing. Just making something good even better." />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="The Happy Class - Making Something Good Even Better" />
  <meta property="og:description" content="A DIY alternative to couples counseling. A physical kit couples do together. Coming October 2026." />
  <meta property="og:url" content="https://thehappyclass.com" />
  <meta property="og:site_name" content="The Happy Class" />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <div class="hero__blob hero__blob--1"></div>
      <div class="hero__blob hero__blob--2"></div>
      <div class="hero__blob hero__blob--3"></div>
