        <div id="waitlist-status" class="waitlist-status" role="alert"></div>
      </form>

      <p style="color: rgba(250,246,240,0.4); font-size: 0.8125rem; margin-top: 1.5rem;">No spam. Just one email when it's time. That's it.</p>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="footer">
    <div class="container text-center">
      <p class="footer__brand">The Happy Class</p>
      <p class="footer__tagline">Making something good <span class="script script--rose">even better.</span></p>
      <div class="footer__links">
        <a href="https://sandraweise.com" target="_blank" rel="noopener noreferrer">sandraweise.com</a>
        <span class="footer__sep">&middot;</span>
        <a href="https://www.instagram.com/sandraweise/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <span class="footer__sep">&middot;</span>
        <a href="https://sandraweise.com/podcast" target="_blank" rel="noopener noreferrer">A Better Question</a>
